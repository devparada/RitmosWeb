---
import Layout from "../layouts/Layout-ant.astro";
import Card from "../components/Card.astro";
---

<Layout title="Ritmos">
  <main>
    <h1>Añade al Bot Ritmos</h1>
    <p class="instructions bg-blue-700">
      🎶 Un bot de música para reproducir tú música favorita de Youtube y
      Spotify 🎶
    </p>
    <ul role="list" class="link-card-grid">
      <Card
        title="/play"
        body="Learn how Astro works and explore the official API docs."
      />
      <Card
        title="/pause"
        body="Supercharge your project with new frameworks and libraries."
      />
      <Card
        title="/skip"
        body="Explore a galaxy of community-built starter themes."
      />
      <Card
        title="/stop"
        body="Come say hi to our amazing Discord community. ❤️"
      />
      <Card
        title="/queue"
        body="Explore a galaxy of community-built starter themes."
      />
      <Card
        title="Proximamente.."
        body="Learn how Astro works and explore the official API docs."
      />
    </ul>
  </main>
</Layout>

<style>
  main {
    margin: auto;
    padding: 1rem;
    width: 800px;
    max-width: calc(100% - 2rem);
    color: white;
    font-size: 20px;
    line-height: 1.6;
  }
  h1 {
    font-size: 4rem;
    font-weight: 700;
    line-height: 1;
    text-align: center;
    margin-bottom: 1em;
  }
  .instructions {
    margin-bottom: 2rem;
    border: 1px solid rgba(var(--accent-light), 25%);
    padding: 1.5rem;
    border-radius: 8px;
  }
  .link-card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(24ch, 1fr));
    gap: 2rem;
    padding: 0;
  }
</style>
